#!/usr/bin/env bash
set -euo pipefail
LC_ALL=C
export LC_ALL

# bin/lobster-run — Lobster workflow runtime
# Traces to: BC-2.12.001, BC-2.12.002, VP-007
#
# Usage: lobster-run [--dry-run] <workflow.yaml>
#
# Environment:
#   CLAUDE_PLUGIN_ROOT — plugin root (used for skill lookup and run-skill.mjs)
#   BRAIN_ROOT        — brain vault root (used for JSONL log output)
#
# Exit codes:
#   0 — all steps succeeded
#   1 — at least one advisory (exit 1 step); no blocks
#   2 — at least one block (exit 2 step), or validation error

# ---------------------------------------------------------------------------
# Generate trace UUID for this invocation (I03)
# ---------------------------------------------------------------------------
if command -v uuidgen >/dev/null 2>&1; then
  RUN_TRACE="$(uuidgen | tr '[:upper:]' '[:lower:]')"
elif [[ -r /proc/sys/kernel/random/uuid ]]; then
  RUN_TRACE="$(cat /proc/sys/kernel/random/uuid)"
else
  # Fallback: timestamp-based pseudo-UUID
  RUN_TRACE="$(printf '%08x-%04x-%04x-%04x-%012x' \
    "$((RANDOM * RANDOM))" "$RANDOM" "$RANDOM" "$RANDOM" "$((RANDOM * RANDOM * RANDOM))")"
fi

# ---------------------------------------------------------------------------
# Millisecond-precision timing using EPOCHREALTIME (bash 5+) (I05)
# ---------------------------------------------------------------------------
_now_ms() {
  if [[ -n "${EPOCHREALTIME:-}" ]]; then
    # EPOCHREALTIME format: "1748000000.123456"
    # Remove the decimal point and strip last 3 digits to get milliseconds
    local er="${EPOCHREALTIME/./}"
    printf '%s' "${er:0:-3}"
  else
    printf '%s' "$((SECONDS * 1000))"
  fi
}

# ---------------------------------------------------------------------------
# Emit lobster.run.completed on stderr and exit with given code (I04)
# ---------------------------------------------------------------------------
_emit_run_completed_and_exit() {
  local exit_code="$1"
  local steps_run="${2:-0}"
  local steps_skipped="${3:-0}"
  local workflow_path="${WORKFLOW_FILE:-unknown}"
  jq -nc \
    --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    --arg trace "$RUN_TRACE" \
    --arg workflow "$workflow_path" \
    --arg hook_name "bin/lobster-run" \
    --argjson exit_code "$exit_code" \
    --argjson steps_run "$steps_run" \
    --argjson steps_skipped "$steps_skipped" \
    '{ts: $ts, event_type: "lobster.run.completed", hook_name: $hook_name, trace: $trace, workflow: $workflow, exit_code: $exit_code, steps_run: $steps_run, steps_skipped: $steps_skipped}' >&2
  exit "$exit_code"
}

# ---------------------------------------------------------------------------
# Argument parsing — flexible: --dry-run may appear before or after workflow
# ---------------------------------------------------------------------------
DRY_RUN=false
WORKFLOW_FILE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
  --dry-run)
    DRY_RUN=true
    shift
    ;;
  --)
    shift
    WORKFLOW_FILE="${1:-}"
    shift
    # S02: warn about extra args after workflow file
    if [[ $# -gt 0 ]]; then
      printf 'Warning: ignoring extra args after workflow file: %s\n' "$*" >&2
    fi
    break
    ;;
  -*)
    printf '{"level":"error","code":"E-LOBSTER-007","message":"Unknown flag: %s"}\n' "$1"
    exit 2
    ;;
  *)
    WORKFLOW_FILE="$1"
    shift
    ;;
  esac
done

# S03: separate error code for missing workflow argument (E-LOBSTER-008)
if [[ -z "$WORKFLOW_FILE" ]]; then
  printf '{"level":"error","code":"E-LOBSTER-008","message":"Missing workflow file argument."}\n'
  _emit_run_completed_and_exit 2
fi

# ---------------------------------------------------------------------------
# Environment resolution
# ---------------------------------------------------------------------------
PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-}"
BRAIN_ROOT="${BRAIN_ROOT:-}"

# Validate BRAIN_ROOT is set
if [[ -z "$BRAIN_ROOT" ]]; then
  printf '{"level":"error","code":"E-LOBSTER-005","message":"BRAIN_ROOT environment variable is not set."}\n'
  _emit_run_completed_and_exit 2
fi

# ---------------------------------------------------------------------------
# YAML validation — attempt to parse; any yq error means malformed
# ---------------------------------------------------------------------------
if ! yq eval '.' "$WORKFLOW_FILE" >/dev/null 2>&1; then
  printf '{"level":"error","code":"E-LOBSTER-003","message":"Invalid workflow YAML: parse error."}\n'
  _emit_run_completed_and_exit 2
fi

# Require steps array to be present and non-empty
step_count="$(yq eval '.steps // [] | length' "$WORKFLOW_FILE" 2>/dev/null || printf '0')"
if ! [[ "$step_count" =~ ^[0-9]+$ ]]; then
  printf '{"level":"error","code":"E-LOBSTER-003","message":"Invalid workflow YAML: missing or malformed steps field."}\n'
  _emit_run_completed_and_exit 2
fi
if [[ "$step_count" -eq 0 ]]; then
  printf '{"level":"error","code":"E-LOBSTER-003","message":"Invalid workflow YAML: missing or empty steps array."}\n'
  _emit_run_completed_and_exit 2
fi

# ---------------------------------------------------------------------------
# Parse steps using per-step JSON extraction (C01: eliminates delimiter problem)
# Each step's full JSON is extracted; jq is used to get individual fields safely.
# ---------------------------------------------------------------------------
declare -a STEP_IDS=()
declare -a STEP_SKILLS=()
declare -A STEP_DEPS=()      # step_id -> comma-separated dep list (for topo sort)
declare -A STEP_ARGS_JSON=() # step_id -> JSON array string of args
declare -A STEP_IDX=()       # step_id -> array index (for validation)

declare -a step_json_lines=()
mapfile -t step_json_lines < <(yq eval -o=json -I=0 '.steps[]' "$WORKFLOW_FILE" 2>/dev/null)

for step_json in "${step_json_lines[@]}"; do
  [[ -z "$step_json" ]] && continue
  sid="$(printf '%s' "$step_json" | jq -r '.id // empty')"
  skill="$(printf '%s' "$step_json" | jq -r '.skill // empty')"
  deps_json="$(printf '%s' "$step_json" | jq -c '.depends_on // []')"
  args_json="$(printf '%s' "$step_json" | jq -c '.args // []')"

  [[ -z "$sid" ]] && continue

  STEP_IDS+=("$sid")
  STEP_SKILLS+=("$skill")
  # Build comma-separated deps string for topo sort compatibility
  deps_csv="$(printf '%s' "$deps_json" | jq -r '.[]' | tr '\n' ',' | sed 's/,$//')"
  STEP_DEPS["$sid"]="$deps_csv"
  STEP_ARGS_JSON["$sid"]="$args_json"
  STEP_IDX["$sid"]="${#STEP_IDS[@]}"
done

# ---------------------------------------------------------------------------
# C02: Skill registration check via plugin.json lookup (spec-compliant)
# ---------------------------------------------------------------------------
local_plugin_manifest="${PLUGIN_ROOT}/.claude-plugin/plugin.json"
if [[ ! -f "$local_plugin_manifest" ]]; then
  printf '{"level":"error","code":"E-LOBSTER-002","message":"Plugin manifest not found at %s"}\n' \
    "$local_plugin_manifest"
  _emit_run_completed_and_exit 2
fi
skills_dir_raw="$(jq -r '.skills // "./skills/"' "$local_plugin_manifest" 2>/dev/null | sed 's|/$||')"
# Resolve relative path (strip leading ./ and prepend PLUGIN_ROOT)
if [[ "$skills_dir_raw" == "./"* ]]; then
  skills_dir="${PLUGIN_ROOT}/${skills_dir_raw#./}"
elif [[ "$skills_dir_raw" == /* ]]; then
  skills_dir="$skills_dir_raw"
else
  skills_dir="${PLUGIN_ROOT}/${skills_dir_raw}"
fi

for sid in "${STEP_IDS[@]}"; do
  idx="${STEP_IDX["$sid"]}"
  skill="${STEP_SKILLS[$((idx - 1))]}"

  # I02: validate skill name — allow optional brain: prefix, kebab-case after
  if ! [[ "$skill" =~ ^(brain:)?[a-z][a-z0-9-]*$ ]]; then
    printf '{"level":"error","code":"E-LOBSTER-002","message":"Skill '\''%s'\'' has invalid name (must be kebab-case with optional brain: prefix)."}\n' "$skill"
    _emit_run_completed_and_exit 2
  fi

  # Strip brain: prefix for directory lookup
  skill_dir_name="${skill#brain:}"
  skill_md="${skills_dir}/${skill_dir_name}/SKILL.md"
  if [[ ! -f "$skill_md" ]]; then
    printf '{"level":"error","code":"E-LOBSTER-002","message":"Skill '\''%s'\'' not found in plugin manifest."}\n' "$skill"
    _emit_run_completed_and_exit 2
  fi
done

# ---------------------------------------------------------------------------
# Kahn's topological sort (BFS) with alphabetical ordering for determinism
# ---------------------------------------------------------------------------
declare -A IN_DEGREE=()
declare -A DEPENDENTS=() # step_id -> space-separated list of steps that depend on it

# Initialize in-degree and dependents map
for sid in "${STEP_IDS[@]}"; do
  IN_DEGREE["$sid"]=0
  DEPENDENTS["$sid"]=""
done

for sid in "${STEP_IDS[@]}"; do
  deps="${STEP_DEPS["$sid"]}"
  if [[ -n "$deps" ]]; then
    declare -a dep_list=()
    mapfile -t dep_list < <(printf '%s' "$deps" | tr ',' '\n')
    for dep in "${dep_list[@]}"; do
      dep="${dep// /}" # strip whitespace
      [[ -z "$dep" ]] && continue
      # E-LOBSTER-004 for unknown dependency reference
      if [[ -z "${IN_DEGREE["$dep"]+isset}" ]]; then
        printf '{"level":"error","code":"E-LOBSTER-004","message":"Unknown dependency '\''%s'\'' referenced by step '\''%s'\''."}\n' "$dep" "$sid"
        _emit_run_completed_and_exit 2
      fi
      IN_DEGREE["$sid"]=$((IN_DEGREE["$sid"] + 1))
      if [[ -z "${DEPENDENTS["$dep"]}" ]]; then
        DEPENDENTS["$dep"]="$sid"
      else
        DEPENDENTS["$dep"]="${DEPENDENTS["$dep"]} $sid"
      fi
    done
  fi
done

# BFS queue seeded with all zero-in-degree nodes (sorted alphabetically)
declare -a QUEUE=()
declare -a TOPO_ORDER=()

declare -a zero_nodes=()
for sid in "${STEP_IDS[@]}"; do
  if [[ "${IN_DEGREE["$sid"]}" -eq 0 ]]; then
    zero_nodes+=("$sid")
  fi
done

if [[ "${#zero_nodes[@]}" -gt 0 ]]; then
  mapfile -t QUEUE < <(printf '%s\n' "${zero_nodes[@]}" | grep -v '^$' | sort)
fi

while [[ "${#QUEUE[@]}" -gt 0 ]]; do
  current="${QUEUE[0]}"
  QUEUE=("${QUEUE[@]:1}")
  TOPO_ORDER+=("$current")

  deps_str="${DEPENDENTS["$current"]}"
  if [[ -n "$deps_str" ]]; then
    declare -a newly_zero=()
    # S01: deps_str is space-separated step IDs — word split is safe here (IDs are kebab-case, no spaces)
    for dep in $deps_str; do
      IN_DEGREE["$dep"]=$((IN_DEGREE["$dep"] - 1))
      if [[ "${IN_DEGREE["$dep"]}" -eq 0 ]]; then
        newly_zero+=("$dep")
      fi
    done
    if [[ "${#newly_zero[@]}" -gt 0 ]]; then
      declare -a sorted_newly_zero=()
      mapfile -t sorted_newly_zero < <(printf '%s\n' "${newly_zero[@]}" | grep -v '^$' | sort)
      if [[ "${#sorted_newly_zero[@]}" -gt 0 ]]; then
        QUEUE+=("${sorted_newly_zero[@]}")
      fi
    fi
  fi
done

# Cycle detection
if [[ "${#TOPO_ORDER[@]}" -ne "${#STEP_IDS[@]}" ]]; then
  printf '{"level":"error","code":"E-LOBSTER-001","message":"Circular dependency detected in workflow."}\n'
  _emit_run_completed_and_exit 2
fi

# ---------------------------------------------------------------------------
# Build step-id to skill lookup (for execution phase)
# ---------------------------------------------------------------------------
declare -A STEP_SKILL_MAP=()
for i in "${!STEP_IDS[@]}"; do
  STEP_SKILL_MAP["${STEP_IDS[$i]}"]="${STEP_SKILLS[$i]}"
done

# ---------------------------------------------------------------------------
# Dry-run mode: print execution plan and exit
# ---------------------------------------------------------------------------
if [[ "$DRY_RUN" == "true" ]]; then
  for sid in "${TOPO_ORDER[@]}"; do
    skill="${STEP_SKILL_MAP["$sid"]}"
    args_json="${STEP_ARGS_JSON["$sid"]:-[]}"
    # Check if args array is non-empty
    args_count="$(printf '%s' "$args_json" | jq 'length')"
    if [[ "$args_count" -gt 0 ]]; then
      # Build space-separated display from JSON array
      args_display="$(printf '%s' "$args_json" | jq -r '.[]' | tr '\n' ' ' | sed 's/ $//')"
      printf '%s: node "%s/scripts/run-skill.mjs" %s %s\n' "$sid" "$PLUGIN_ROOT" "$skill" "$args_display"
    else
      printf '%s: node "%s/scripts/run-skill.mjs" %s\n' "$sid" "$PLUGIN_ROOT" "$skill"
    fi
  done
  exit 0
fi

# ---------------------------------------------------------------------------
# Execution mode: run each step, write JSONL log, honor exit-code contract
# ---------------------------------------------------------------------------
LOG_DATE="$(date -u +%Y-%m-%d)"
LOG_DIR="${BRAIN_ROOT}/.brain/logs"
LOG_FILE="${LOG_DIR}/lobster-${LOG_DATE}.jsonl"

if ! mkdir -p "$LOG_DIR" 2>/dev/null; then
  printf '{"level":"error","code":"E-LOBSTER-006","message":"Cannot create log directory: %s"}\n' "$LOG_DIR"
  _emit_run_completed_and_exit 2
fi

OVERALL_EXIT=0
STEPS_RUN=0
STEPS_SKIPPED=0

for sid in "${TOPO_ORDER[@]}"; do
  skill="${STEP_SKILL_MAP["$sid"]}"
  args_json="${STEP_ARGS_JSON["$sid"]:-[]}"

  step_start_ms="$(_now_ms)"

  step_exit=0

  # Build args array from JSON array using mapfile (no bare read, no delimiter bugs)
  declare -a step_args=()
  args_count="$(printf '%s' "$args_json" | jq 'length')"
  if [[ "$args_count" -gt 0 ]]; then
    mapfile -t step_args < <(printf '%s' "$args_json" | jq -r '.[]')
  fi

  if [[ "${#step_args[@]}" -gt 0 ]]; then
    node "${PLUGIN_ROOT}/scripts/run-skill.mjs" "$skill" "${step_args[@]}" || step_exit="$?"
  else
    node "${PLUGIN_ROOT}/scripts/run-skill.mjs" "$skill" || step_exit="$?"
  fi

  step_end_ms="$(_now_ms)"
  step_duration=$((step_end_ms - step_start_ms))

  # Determine verdict
  case "$step_exit" in
  0) verdict="allow" ;;
  1) verdict="advisory" ;;
  2) verdict="block" ;;
  *)
    verdict="block"
    step_exit=2
    ;;
  esac

  STEPS_RUN=$((STEPS_RUN + 1))

  # Write JSONL log entry
  jq -nc \
    --arg step_id "$sid" \
    --arg verdict "$verdict" \
    --argjson exit_code "$step_exit" \
    --argjson duration_ms "$step_duration" \
    '{"step_id": $step_id, "exit_code": $exit_code, "verdict": $verdict, "duration_ms": $duration_ms}' \
    >>"$LOG_FILE"

  # Emit lobster.step.completed event on stderr
  {
    ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    jq -nc \
      --arg ts "$ts" \
      --arg step_id "$sid" \
      --arg verdict "$verdict" \
      --arg hook_name "bin/lobster-run" \
      --arg trace "$RUN_TRACE" \
      --argjson exit_code "$step_exit" \
      --argjson duration_ms "$step_duration" \
      '{"ts": $ts, "event_type": "lobster.step.completed", "hook_name": $hook_name, "trace": $trace, "step_id": $step_id, "exit_code": $exit_code, "verdict": $verdict, "duration_ms": $duration_ms}'
  } >&2

  if [[ "$step_exit" -eq 2 ]]; then
    # Block: stop immediately; remaining steps are skipped
    STEPS_SKIPPED=$((${#TOPO_ORDER[@]} - STEPS_RUN))
    _emit_run_completed_and_exit 2 "$STEPS_RUN" "$STEPS_SKIPPED"
  elif [[ "$step_exit" -eq 1 ]]; then
    OVERALL_EXIT=1
  fi
done

# Emit lobster.run.completed event on stderr (successful/advisory completion)
_emit_run_completed_and_exit "$OVERALL_EXIT" "$STEPS_RUN" 0
